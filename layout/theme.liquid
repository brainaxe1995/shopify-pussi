<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="#010d1a">
  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- else -%}
    <link rel="icon" type="image/png" href="{{ 'favicon.png' | asset_url }}">
  {%- endif -%}
  <title>
    {{ page_title }}{% if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}

  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=DM+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'product-card.css' | asset_url | stylesheet_tag }}
  {{ 'badges.css' | asset_url | stylesheet_tag }}
  {{ 'side-cart.css' | asset_url | stylesheet_tag }}
  <style>
    /* Hard override of body top padding (Shopify sometimes lags on theme.css updates).
       Header height = announce bar (~30) + nav row (~80) = ~110-120; 150 buffers. */
    body{padding-top:150px !important;}
    @media(max-width:900px){body{padding-top:80px !important;}}
  </style>

  <script>
    window.PK = {
      routes: {
        cart_add: '{{ routes.cart_add_url }}.js',
        cart_change: '{{ routes.cart_change_url }}.js',
        cart_update: '{{ routes.cart_update_url }}.js',
        cart: '{{ routes.cart_url }}.js',
        cart_page: '{{ routes.cart_url }}',
        checkout: '/checkout'
      },
      currency: {{ shop.currency | json }},
      money_format: {{ shop.money_format | json }},
      free_ship_threshold: {{ settings.free_ship_threshold | default: 100 }},
      flash_enabled: {{ settings.flash_enabled | default: true }},
      flash_timer_min: {{ settings.flash_timer_min | default: 15 }},
      flash_discount_pct: {{ settings.flash_discount_pct | default: 25 }},
      flash_collection: {{ settings.flash_collection_handle | default: '' | json }}
    };
  </script>

  {{ content_for_header }}
</head>
<body class="pk-body">
  <a class="pk-skip" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>
  {% sections 'header-group' %}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {% render 'cart-drawer' %}

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script src="{{ 'side-cart.js' | asset_url }}" defer></script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
