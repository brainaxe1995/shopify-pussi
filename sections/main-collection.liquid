<div class="pk-collection-head">
  <h1>{{ collection.title }}</h1>
  {%- if collection.description != blank -%}<p>{{ collection.description }}</p>{%- endif -%}
</div>

<section class="pk-section">
  <div class="pk-grid pk-grid-4">
    {%- paginate collection.products by section.settings.per_page -%}
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        <p>Ei tuotteita.</p>
      {%- endfor -%}

      {%- if paginate.pages > 1 -%}
        <div class="pk-pagination" style="grid-column:1/-1;">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">&laquo;</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}<span {% if part.title == paginate.current_page %}aria-current="page"{% endif %}>{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">&raquo;</a>{%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "range", "id": "per_page", "min": 8, "max": 48, "step": 4, "default": 24, "label": "Products per page" }
  ]
}
{% endschema %}
