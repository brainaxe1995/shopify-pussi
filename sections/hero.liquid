<style>
.pk-hero{background:var(--abyss);text-align:center;}
.pk-hero-img{width:100%;height:auto;display:block;}
.pk-hero-text{padding:20px 24px 24px;background:var(--abyss);}
.pk-hero-text h1{font-family:var(--ff);font-size:clamp(22px,3.5vw,40px);font-weight:900;color:#fff;letter-spacing:-1px;line-height:1.05;margin-bottom:6px;}
.pk-hero-text h1 em{font-style:normal;display:block;background:var(--g-aurora);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.pk-hero-guarantee{display:inline-flex;align-items:center;gap:6px;background:rgba(0,229,255,.1);border:1.5px solid rgba(0,229,255,.25);border-radius:20px;padding:6px 16px;margin-bottom:10px;font-family:var(--ff);font-size:13px;font-weight:700;color:#fff;letter-spacing:.2px;}
.pk-hero-guarantee i{color:#00e5ff;font-size:12px;}
.pk-hero-delivery{font-family:var(--ff);font-size:11px;font-weight:600;color:var(--frost);letter-spacing:.3px;margin-bottom:14px;opacity:.7;}
.pk-hero-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
@media(max-width:480px){.pk-hero-text{padding:14px 16px 18px;}.pk-hero-text h1{font-size:19px;}.pk-hero-guarantee{font-size:11px;padding:5px 12px;}.pk-hero-delivery{font-size:10px;margin-bottom:10px;}}
</style>

<section class="pk-hero">
  <picture>
    {%- if section.settings.image_mobile != blank -%}
      <source media="(max-width:768px)" srcset="{{ section.settings.image_mobile | image_url: width: 800 }}">
    {%- else -%}
      <source media="(max-width:768px)" srcset="{{ 'hero2.png' | asset_url }}">
    {%- endif -%}
    {%- if section.settings.image_desktop != blank -%}
      <img src="{{ section.settings.image_desktop | image_url: width: 1600 }}" alt="{{ section.settings.heading | escape }}" class="pk-hero-img">
    {%- else -%}
      <img src="{{ 'hero-2.png' | asset_url }}" alt="{{ section.settings.heading | escape }}" class="pk-hero-img">
    {%- endif -%}
  </picture>
  <div class="pk-hero-text">
    <h1>{{ section.settings.heading | default: 'Suosituimmat tuotteet.' }}<br><em>{{ section.settings.heading_em | default: 'Parhailla hinnoilla.' }}</em></h1>
    <div class="pk-hero-guarantee"><i class="fas fa-shield-halved"></i> {{ section.settings.guarantee | default: '100% toimitustakuu suoraan Ruotsista' }}</div>
    <p class="pk-hero-delivery">{{ section.settings.delivery_line | default: 'Palvelemme suomeksi · Ilmainen toimitus yli 100€ · 3–5 arkipäivää' }}</p>
    <div class="pk-hero-btns">
      <a class="pk-btn-ice" href="{{ section.settings.cta1_url | default: routes.all_products_collection_url }}"><i class="fas fa-shopping-bag"></i> {{ section.settings.cta1_label | default: 'Kauppa' }}</a>
      <a class="pk-btn-ghost" href="{{ section.settings.cta2_url | default: '/pages/about-us' }}">{{ section.settings.cta2_label | default: 'Tietoa meistä' }} <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image_desktop", "label": "Desktop image" },
    { "type": "image_picker", "id": "image_mobile",  "label": "Mobile image (optional)" },
    { "type": "text", "id": "heading",       "label": "Heading",        "default": "Suosituimmat tuotteet." },
    { "type": "text", "id": "heading_em",    "label": "Heading accent", "default": "Parhailla hinnoilla." },
    { "type": "text", "id": "guarantee",     "label": "Guarantee chip", "default": "100% toimitustakuu suoraan Ruotsista" },
    { "type": "text", "id": "delivery_line", "label": "Delivery line",  "default": "Palvelemme suomeksi · Ilmainen toimitus yli 100€ · 3–5 arkipäivää" },
    { "type": "text", "id": "cta1_label",    "label": "Primary CTA label", "default": "Kauppa" },
    { "type": "url",  "id": "cta1_url",      "label": "Primary CTA url" },
    { "type": "text", "id": "cta2_label",    "label": "Secondary CTA label", "default": "Tietoa meistä" },
    { "type": "url",  "id": "cta2_url",      "label": "Secondary CTA url" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
