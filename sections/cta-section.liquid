<style>
.pk-cta-sec{position:relative;padding:80px 0;overflow:hidden;background:linear-gradient(135deg,var(--abyss) 0%,var(--deep) 100%);}
.pk-cta-sec::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(0,229,255,.12) 0%,transparent 50%),radial-gradient(ellipse at 70% 50%,rgba(72,202,228,.08) 0%,transparent 40%);z-index:0;}
.pk-cta-inner{position:relative;z-index:1;text-align:center;max-width:600px;margin:0 auto;padding:0 24px;}
.pk-cta-inner h2{font-family:var(--ff);font-size:clamp(28px,4vw,42px);font-weight:900;color:#fff;letter-spacing:-.5px;margin-bottom:12px;line-height:1.05;}
.pk-cta-inner h2 span{color:var(--ice);}
.pk-cta-inner p{font-family:var(--fb);font-size:15px;color:var(--frost);opacity:.7;margin-bottom:28px;line-height:1.6;}
</style>

<section class="pk-cta-sec">
  <div class="pk-cta-inner pk-reveal">
    <h2>{{ section.settings.heading | default: 'Sinun pussisi.' }}<br><span>{{ section.settings.heading_em | default: 'Sinun valintasi.' }}</span></h2>
    <p>{{ section.settings.body | default: 'Neljä premium-brändiä Ruotsista. Suomen suosituimmat pussit parhaaseen hintaan. 100% toimitustakuu. Rahat takaisin, jos lähetystä ei kuulu. Tilaa tänään — toimitus 3–5 arkipäivässä.' }}</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a class="pk-btn-ice" href="{{ section.settings.cta1_url | default: routes.all_products_collection_url }}"><i class="fas fa-shopping-bag"></i> {{ section.settings.cta1_label | default: 'Koko valikoima' }}</a>
      <a class="pk-btn-ghost" href="{{ section.settings.cta2_url | default: '/pages/contact-us' }}"><i class="fas fa-envelope"></i> {{ section.settings.cta2_label | default: 'Ota yhteyttä' }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA section",
  "settings": [
    { "type": "text",     "id": "heading",     "label": "Heading",          "default": "Sinun pussisi." },
    { "type": "text",     "id": "heading_em",  "label": "Heading accent",   "default": "Sinun valintasi." },
    { "type": "textarea", "id": "body",        "label": "Body" },
    { "type": "text",     "id": "cta1_label",  "label": "Primary CTA label","default": "Koko valikoima" },
    { "type": "url",      "id": "cta1_url",    "label": "Primary CTA url" },
    { "type": "text",     "id": "cta2_label",  "label": "Secondary CTA label","default": "Ota yhteyttä" },
    { "type": "url",      "id": "cta2_url",    "label": "Secondary CTA url" }
  ],
  "presets": [{ "name": "CTA" }]
}
{% endschema %}
