<style>
.pk-ref-promo{background:linear-gradient(135deg,#0b2545 0%,#0d1b30 50%,#091424 100%);border-top:1px solid rgba(0,229,255,.12);border-bottom:1px solid rgba(0,229,255,.12);padding:56px 0;position:relative;overflow:hidden;}
.pk-ref-promo::before{content:'';position:absolute;top:-80px;right:-80px;width:360px;height:360px;background:radial-gradient(circle,rgba(0,229,255,.07) 0%,transparent 70%);pointer-events:none;}
.pk-ref-promo-inner{display:flex;align-items:center;gap:48px;max-width:1340px;margin:0 auto;padding:0 24px;}
@media(max-width:768px){.pk-ref-promo-inner{flex-direction:column;gap:32px;text-align:center;padding:0 16px;}}
.pk-ref-promo-left{flex:1;}
.pk-ref-eye{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#00e5ff;margin-bottom:12px;display:block;}
.pk-ref-title{font-family:var(--ff);font-size:30px;font-weight:800;color:#fff;line-height:1.15;margin-bottom:12px;letter-spacing:-.5px;}
.pk-ref-title em{font-style:normal;color:#00e5ff;}
@media(max-width:768px){.pk-ref-title{font-size:24px;}}
.pk-ref-desc{font-size:14px;color:rgba(144,224,239,.75);line-height:1.7;margin-bottom:20px;max-width:480px;}
.pk-ref-desc strong{color:#caf0f8;}
@media(max-width:768px){.pk-ref-desc{max-width:100%;}}
.pk-ref-steps{display:flex;flex-direction:column;gap:10px;margin-bottom:24px;}
.pk-ref-step{display:flex;align-items:center;gap:10px;font-size:13px;color:rgba(202,240,248,.8);}
@media(max-width:768px){.pk-ref-step{justify-content:center;}}
.pk-ref-n{width:22px;height:22px;border-radius:50%;background:rgba(0,229,255,.15);border:1px solid rgba(0,229,255,.3);font-size:11px;font-weight:800;color:#00e5ff;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.pk-ref-btn{display:inline-flex;align-items:center;gap:8px;padding:13px 26px;background:linear-gradient(135deg,#00b4d8,#00e5ff);color:#0a1628;border-radius:10px;font-family:var(--ff);font-size:14px;font-weight:800;text-decoration:none;transition:.2s;}
.pk-ref-btn:hover{opacity:.9;transform:translateY(-2px);color:#0a1628;}
.pk-ref-promo-right{display:flex;align-items:center;gap:16px;flex-shrink:0;}
@media(max-width:768px){.pk-ref-promo-right{justify-content:center;}}
.pk-ref-badge{background:rgba(0,180,216,.08);border:1.5px solid rgba(0,180,216,.25);border-radius:16px;padding:24px 28px;text-align:center;min-width:110px;}
.pk-ref-badge-icon{font-size:22px;color:#00e5ff;margin-bottom:6px;}
.pk-ref-badge-val{font-family:var(--ff);font-size:36px;font-weight:900;color:#00e5ff;line-height:1;}
.pk-ref-badge-lbl{font-size:12px;color:rgba(144,224,239,.7);margin-top:4px;font-weight:600;}
.pk-ref-badge--friend .pk-ref-badge-icon{color:#48cae4;}
.pk-ref-badge--friend .pk-ref-badge-val{color:#48cae4;}
.pk-ref-badge--friend{border-color:rgba(0,180,216,.15);}
.pk-ref-plus{font-size:28px;font-weight:800;color:rgba(0,229,255,.4);}
</style>

<section class="pk-ref-promo">
  <div class="pk-ref-promo-inner">
    <div class="pk-ref-promo-left">
      <span class="pk-ref-eye">{{ section.settings.eyebrow | default: '⚡ Suomen paras suositteluohjelma' }}</span>
      <h2 class="pk-ref-title">Kerro kaverille — <em>säästä -{{ section.settings.discount | default: 20 }}%</em></h2>
      <p class="pk-ref-desc">Luo oma suosittelulinkkisi ja jaa se kaverillesi. Hän saa <strong>-{{ section.settings.discount | default: 20 }}%</strong> ensimmäisestä tilauksestaan — ja sinä saat <strong>-{{ section.settings.discount | default: 20 }}%</strong> seuraavaan tilaukseesi heti kun hän tilaa.</p>
      <div class="pk-ref-steps">
        <div class="pk-ref-step"><span class="pk-ref-n">1</span><span>Luo tili &amp; kopioi oma linkkisi</span></div>
        <div class="pk-ref-step"><span class="pk-ref-n">2</span><span>Jaa linkki kaverille esim. WhatsAppissa</span></div>
        <div class="pk-ref-step"><span class="pk-ref-n">3</span><span>Kaveri tilaa → molemmat säästävät</span></div>
      </div>
      <a href="{{ routes.account_register_url }}" class="pk-ref-btn"><i class="fas fa-user-plus"></i> Luo tilisi tästä</a>
    </div>
    <div class="pk-ref-promo-right">
      <div class="pk-ref-badge">
        <div class="pk-ref-badge-icon"><i class="fas fa-gift"></i></div>
        <div class="pk-ref-badge-val">-{{ section.settings.discount | default: 20 }}%</div>
        <div class="pk-ref-badge-lbl">sinulle</div>
      </div>
      <div class="pk-ref-plus">+</div>
      <div class="pk-ref-badge pk-ref-badge--friend">
        <div class="pk-ref-badge-icon"><i class="fas fa-heart"></i></div>
        <div class="pk-ref-badge-val">-{{ section.settings.discount | default: 20 }}%</div>
        <div class="pk-ref-badge-lbl">kaverille</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Referral promo",
  "settings": [
    { "type": "text",   "id": "eyebrow",  "label": "Eyebrow text", "default": "⚡ Suomen paras suositteluohjelma" },
    { "type": "number", "id": "discount", "label": "Discount %",   "default": 20 }
  ],
  "presets": [{ "name": "Referral promo" }]
}
{% endschema %}
