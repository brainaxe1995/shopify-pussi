<style>
.pk-brands-section{position:relative;}
.pk-brands-section::before{content:'';position:absolute;inset:0;background:rgba(1,13,26,.8);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);z-index:0;}
.pk-brands-section .pk-wrap{position:relative;z-index:1;}
.pk-brands{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
@media(max-width:900px){.pk-brands{grid-template-columns:1fr 1fr;}}
@media(max-width:480px){.pk-brands{grid-template-columns:1fr;}}
.pk-brand{background:rgba(1,13,26,.4);border:1px solid rgba(0,229,255,.1);border-radius:var(--rl);padding:24px;backdrop-filter:blur(16px) saturate(1.2);-webkit-backdrop-filter:blur(16px) saturate(1.2);transition:.3s;position:relative;overflow:hidden;text-decoration:none;display:block;box-shadow:0 4px 24px rgba(0,0,0,.15),inset 0 1px 0 rgba(255,255,255,.03);}
.pk-brand::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--g-aurora);transform:scaleX(0);transform-origin:left;transition:.3s;}
.pk-brand:hover{border-color:rgba(0,229,255,.3);transform:translateY(-4px);box-shadow:0 16px 48px rgba(0,0,0,.3),0 0 40px rgba(0,229,255,.06);}
.pk-brand:hover::before{transform:scaleX(1);}
.pk-brand-img{width:80px;height:80px;border-radius:50%;background:rgba(0,229,255,.04);border:1px solid rgba(0,229,255,.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;overflow:hidden;}
.pk-brand-img img{width:64px;height:64px;object-fit:contain;}
.pk-brand-img i{font-size:28px;color:var(--ice);}
.pk-brand-name{font-family:var(--ff);font-size:18px;font-weight:800;color:#fff;text-align:center;margin-bottom:4px;}
.pk-brand-meta{font-size:12px;color:var(--dim);text-align:center;line-height:1.5;}
.pk-brand-tag{display:flex;justify-content:center;align-items:center;gap:4px;font-family:var(--ff);font-size:9px;font-weight:700;color:var(--ice);background:rgba(0,229,255,.08);border:1px solid rgba(0,229,255,.12);padding:3px 10px;border-radius:20px;margin-top:12px;width:fit-content;margin-left:auto;margin-right:auto;}
.pk-brand-cta{display:block;text-align:center;margin-top:14px;font-family:var(--ff);font-size:12px;font-weight:600;color:var(--aurora);transition:.15s;}
.pk-brand:hover .pk-brand-cta{color:var(--ice);}
</style>

{%- if section.settings.bg_image != blank -%}
  {%- assign bg_bg = section.settings.bg_image | image_url: width: 1920 -%}
{%- else -%}
  {%- assign bg_bg = 'ice3.jpg' | asset_url -%}
{%- endif -%}
<section class="pk-sec pk-brands-section" style="background:url('{{ bg_bg }}') center/cover no-repeat fixed;">
  <div class="pk-wrap">
    <div class="pk-sec-hdr pk-reveal">
      <span class="pk-sec-eye">{{ section.settings.eyebrow | default: 'Valikoimamme' }}</span>
      <div class="pk-sec-title">{{ section.settings.heading | default: 'Neljä brändiä. Yksi standardi.' }}</div>
      <p class="pk-sec-sub">{{ section.settings.subheading | default: 'Vain tunnettujen skandinaavisten valmistajien tuotteita.' }}</p>
    </div>
    <div class="pk-brands pk-reveal">
      {%- for block in section.blocks -%}
        <a class="pk-brand" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          <div class="pk-brand-img">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 128 }}" alt="{{ block.settings.name | escape }}">
            {%- elsif block.settings.default_asset != blank -%}
              <img src="{{ block.settings.default_asset | asset_url }}" alt="{{ block.settings.name | escape }}">
            {%- else -%}
              <i class="fas fa-{{ block.settings.icon | default: 'snowflake' }}"></i>
            {%- endif -%}
          </div>
          <div class="pk-brand-name">{{ block.settings.name }}</div>
          <div class="pk-brand-meta">{{ block.settings.meta }}</div>
          {%- if block.settings.tag != blank -%}
            <div class="pk-brand-tag"><i class="fas fa-{{ block.settings.tag_icon | default: 'bolt' }}"></i> {{ block.settings.tag }}</div>
          {%- endif -%}
          <div class="pk-brand-cta">{{ block.settings.cta | default: 'Osta nyt' }} <i class="fas fa-arrow-right"></i></div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brands grid",
  "max_blocks": 8,
  "settings": [
    { "type": "text",        "id": "eyebrow",    "label": "Eyebrow",     "default": "Valikoimamme" },
    { "type": "text",        "id": "heading",    "label": "Heading",     "default": "Neljä brändiä. Yksi standardi." },
    { "type": "text",        "id": "subheading", "label": "Subheading",  "default": "Vain tunnettujen skandinaavisten valmistajien tuotteita." },
    { "type": "image_picker","id": "bg_image",   "label": "Background image (optional)" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        { "type": "image_picker", "id": "image",    "label": "Logo" },
        { "type": "text",         "id": "default_asset", "label": "Default asset filename", "default": "odens-icon.png" },
        { "type": "text",         "id": "icon",     "label": "Fallback FontAwesome name", "default": "fire" },
        { "type": "text",         "id": "name",     "label": "Brand name" },
        { "type": "text",         "id": "meta",     "label": "Meta line" },
        { "type": "text",         "id": "tag",      "label": "Tag (small badge)" },
        { "type": "text",         "id": "tag_icon", "label": "Tag icon (FA name)", "default": "bolt" },
        { "type": "text",         "id": "cta",      "label": "CTA label", "default": "Osta" },
        { "type": "url",          "id": "url",      "label": "URL" }
      ]
    }
  ],
  "presets": [{
    "name": "Brands grid",
    "blocks": [
      { "type": "brand", "settings": { "name": "Oden's",   "default_asset": "odens-icon.png",    "meta": "Cold Dry Extreme White\n13.2mg · Original 0.75g", "tag": "Extreme",       "tag_icon": "bolt",    "cta": "Osta Oden's",   "icon": "fire" } },
      { "type": "brand", "settings": { "name": "White Fox","default_asset": "whitefox-icon.png", "meta": "3 makua · All White Portion\n12mg · Slim 0.75g",    "tag": "Suosituin",     "tag_icon": "star",    "cta": "Osta White Fox","icon": "snowflake" } },
      { "type": "brand", "settings": { "name": "VELO",     "default_asset": "velo-icon.png",     "meta": "2 makua · Nicotine Pouches\n10–14mg · Slim 0.7g",   "tag": "Maailman #1",   "tag_icon": "globe",   "cta": "Osta VELO",     "icon": "leaf" } },
      { "type": "brand", "settings": { "name": "GREATEST", "default_asset": "greatest-icon.png", "meta": "White Gold Cold Dry\n12mg · Slim 0.7g",             "tag": "G.O.A.T",       "tag_icon": "trophy",  "cta": "Osta GREATEST", "icon": "gem" } }
    ]
  }]
}
{% endschema %}
