<style>
.au-hero{background:var(--bg-deep);min-height:320px;display:flex;align-items:center;justify-content:center;text-align:center;padding:52px 20px;position:relative;overflow:hidden;}
.au-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(0,229,255,.12) 0%,transparent 60%);pointer-events:none;}
.au-hero-in{position:relative;z-index:1;max-width:640px;}
.au-hero-eye{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;color:var(--f);display:block;margin-bottom:12px;}
.au-hero h1{font-family:var(--ff);font-size:40px;font-weight:900;color:#fff;letter-spacing:-.8px;line-height:1.05;margin-bottom:14px;}
.au-hero h1 span{color:var(--f);}
.au-hero p{font-size:15px;color:rgba(202,240,248,.7);line-height:1.65;margin-bottom:22px;}
.au-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
.au-btn{display:inline-flex;align-items:center;gap:7px;padding:11px 22px;border-radius:8px;font-size:13px;font-weight:700;text-decoration:none;transition:.18s;}
.au-btn-w{background:var(--g);color:#0a1628;}.au-btn-w:hover{opacity:.88;color:#0a1628;}
.au-btn-g{background:rgba(0,180,216,.08);color:var(--f);border:1.5px solid var(--bdr);}.au-btn-g:hover{background:rgba(0,180,216,.15);}
@media(max-width:768px){.au-hero{min-height:unset;padding:40px 16px;}.au-hero h1{font-size:28px;}.au-hero p{font-size:13.5px;}}

.au-wrap{max-width:1100px;margin:0 auto;padding:0 20px;}
@media(max-width:768px){.au-wrap{padding:0 14px;}}
.au-sec{padding:44px 0;}
@media(max-width:768px){.au-sec{padding:28px 0;}}

.au-stats{display:grid;grid-template-columns:repeat(4,1fr);border:1.5px solid var(--bdr);border-radius:14px;background:var(--w);overflow:hidden;margin-bottom:36px;box-shadow:var(--sh);}
.au-stat{text-align:center;padding:20px 10px;border-right:1.5px solid var(--bdr);}.au-stat:last-child{border-right:none;}
.au-stat-n{font-size:28px;font-weight:900;color:var(--f);display:block;line-height:1;margin-bottom:4px;letter-spacing:-.5px;}
.au-stat-l{font-size:11px;color:var(--mu);}
@media(max-width:560px){.au-stats{grid-template-columns:1fr 1fr;}.au-stat:nth-child(2){border-right:none;}.au-stat:nth-child(3){border-top:1.5px solid var(--bdr);border-right:1.5px solid var(--bdr);}.au-stat:nth-child(4){border-top:1.5px solid var(--bdr);}.au-stat-n{font-size:24px;}}

.au-split{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;margin-bottom:44px;}
@media(max-width:768px){.au-split{grid-template-columns:1fr;gap:20px;}}
.au-split-img{border-radius:14px;overflow:hidden;background:var(--bg2);}
.au-split-img img{width:100%;height:auto;display:block;}
.au-split-eye{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1.3px;color:var(--v);display:block;margin-bottom:10px;}
.au-split h2{font-family:var(--ff);font-size:26px;font-weight:900;color:var(--txt);letter-spacing:-.5px;margin-bottom:12px;line-height:1.15;}
@media(max-width:768px){.au-split h2{font-size:22px;}}
.au-split p{font-size:14px;color:var(--mid);line-height:1.75;margin-bottom:12px;}

.au-vals{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:44px;}
@media(max-width:768px){.au-vals{grid-template-columns:1fr 1fr;}}
@media(max-width:480px){.au-vals{grid-template-columns:1fr;gap:10px;}}
.au-val{background:var(--w);border:1.5px solid var(--bdr);border-radius:14px;padding:22px 18px;box-shadow:var(--sh);position:relative;overflow:hidden;transition:.2s;}
.au-val::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--g);transform:scaleX(0);transform-origin:left;transition:.25s;}
.au-val:hover{border-color:var(--v);transform:translateY(-2px);box-shadow:var(--shh);}
.au-val:hover::before{transform:scaleX(1);}
.au-val-ico{width:44px;height:44px;border-radius:14px;background:var(--vl);display:flex;align-items:center;justify-content:center;margin-bottom:12px;transition:.18s;}
.au-val:hover .au-val-ico{background:var(--v);}
.au-val-ico i{font-size:19px;color:var(--v);transition:.18s;}
.au-val:hover .au-val-ico i{color:#fff;}
.au-val h3{font-family:var(--ff);font-size:14px;font-weight:700;color:var(--txt);margin-bottom:6px;}
.au-val p{font-size:12.5px;color:var(--mu);line-height:1.55;}

.au-dk{background:var(--bg-deep);padding:52px 0;position:relative;overflow:hidden;}
.au-dk::before{content:'';position:absolute;top:-80px;right:-80px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(0,229,255,.08) 0%,transparent 70%);}
.au-dk-in{text-align:center;position:relative;z-index:1;}
.au-dk-in .eye{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1.3px;color:var(--f);display:block;margin-bottom:12px;}
.au-dk-in h2{font-family:var(--ff);font-size:30px;font-weight:900;color:#fff;letter-spacing:-.6px;margin-bottom:12px;}
@media(max-width:768px){.au-dk-in h2{font-size:22px;}}
.au-dk-in p{font-size:14px;color:rgba(202,240,248,.6);line-height:1.65;max-width:520px;margin:0 auto 24px;}
</style>

<div class="au-hero">
  <div class="au-hero-in">
    <span class="au-hero-eye">Tietoa meistä</span>
    <h1>Pussikauppa — laatu edellä.<br><span>Aina.</span></h1>
    <p>Myymme vain premium-nikotiinipusseja tunnetuilta valmistajilta. Rehellisiä hintoja, nopeaa toimitusta ja aitoa asiakaspalvelua.</p>
    <div class="au-btns">
      <a class="au-btn au-btn-w" href="{{ routes.all_products_collection_url }}"><i class="fas fa-shopping-bag"></i> Kauppaan</a>
      <a class="au-btn au-btn-g" href="/pages/contact-us"><i class="fas fa-envelope"></i> Ota yhteyttä</a>
    </div>
  </div>
</div>

<div class="au-sec" style="background:var(--w);">
  <div class="au-wrap">
    <div class="au-stats">
      <div class="au-stat"><span class="au-stat-n">4</span><span class="au-stat-l">Brändiä</span></div>
      <div class="au-stat"><span class="au-stat-n">7</span><span class="au-stat-l">Makua</span></div>
      <div class="au-stat"><span class="au-stat-n">20</span><span class="au-stat-l">Pussia / purkki</span></div>
      <div class="au-stat"><span class="au-stat-n">3–5</span><span class="au-stat-l">Pv toimitusaika</span></div>
    </div>
    <div class="au-split">
      <div class="au-split-img">
        {%- if section.settings.split_image != blank -%}
          <img src="{{ section.settings.split_image | image_url: width: 800 }}" alt="Tietoa {{ shop.name | escape }}" loading="lazy">
        {%- else -%}
          <img src="{{ 'about.jpg' | asset_url }}" alt="Tietoa {{ shop.name | escape }}" loading="lazy">
        {%- endif -%}
      </div>
      <div>
        <span class="au-split-eye">Keitä me olemme</span>
        <h2>Pussikauppa on Suomen nikotiinipussien erikoiskauppa.</h2>
        <p>Testatut tuotteet, rehellinen hinnoittelu ja nopea toimitus. Myymme vain tunnettujen valmistajien tuotteita — Oden's, White Fox, VELO ja GREATEST.</p>
        <p>Ei kikkailua. Ei selittelyä. Vain laadukkaita nikotiinipusseja reilulla hinnalla.</p>
      </div>
    </div>
  </div>
</div>

<div class="au-sec" style="background:var(--bg);">
  <div class="au-wrap">
    <div style="text-align:center;margin-bottom:24px;">
      <span style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1.3px;color:var(--v);display:block;margin-bottom:5px;">Mitä me edustamme</span>
      <h2 style="font-family:var(--ff);font-size:24px;font-weight:900;color:var(--txt);letter-spacing:-.4px;">Arvomme</h2>
    </div>
    <div class="au-vals">
      <div class="au-val"><div class="au-val-ico"><i class="fas fa-check-double"></i></div><h3>Vain premium-tuotteet</h3><p>Myymme ainoastaan tunnettujen valmistajien laadukkaita nikotiinipusseja.</p></div>
      <div class="au-val"><div class="au-val-ico"><i class="fas fa-euro-sign"></i></div><h3>Rehellinen hinnoittelu</h3><p>Reilut hinnat ilman turhaa kiiltoa. Tukkualennukset suurille tilauksille.</p></div>
      <div class="au-val"><div class="au-val-ico"><i class="fas fa-truck-fast"></i></div><h3>Nopea toimitus</h3><p>Toimitusaika 3–5 arkipäivää. Ilmainen yli 100€ tilauksiin. Seuranta aina mukana.</p></div>
      <div class="au-val"><div class="au-val-ico"><i class="fas fa-headset"></i></div><h3>Luotettava asiakaspalvelu</h3><p>Autamme mielellämme kaikissa kysymyksissä. Arkisin paikalla.</p></div>
      <div class="au-val"><div class="au-val-ico"><i class="fas fa-snowflake"></i></div><h3>Skandinaaviset brändit</h3><p>Oden's, White Fox, VELO ja GREATEST — pohjoismaista laatua.</p></div>
      <div class="au-val"><div class="au-val-ico"><i class="fas fa-leaf"></i></div><h3>Tupakaton vaihtoehto</h3><p>Kaikki tuotteemme ovat 100% tupakattomia nikotiinipusseja.</p></div>
    </div>
  </div>
</div>

<div class="au-dk">
  <div class="au-wrap">
    <div class="au-dk-in">
      <span class="eye">Valmiina kokeilemaan?</span>
      <h2>Löydä oma pussisi</h2>
      <p>Oden's, White Fox, VELO ja GREATEST — neljä brändiä, seitsemän makua, 10–14mg nikotiinia. Tilaa tänään.</p>
      <div class="au-btns">
        <a class="au-btn au-btn-w" href="{{ routes.all_products_collection_url }}"><i class="fas fa-shopping-bag"></i> Kaikki tuotteet</a>
        <a class="au-btn au-btn-g" href="/pages/contact-us"><i class="fas fa-envelope"></i> Ota yhteyttä</a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About page",
  "settings": [
    { "type": "image_picker", "id": "split_image", "label": "About split image" }
  ]
}
{% endschema %}
