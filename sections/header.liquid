<style>
/* ═══ HEADER — Frozen Norse v3 ═══ */
.pk-hdr{position:fixed;top:0;left:0;right:0;z-index:999;background:rgba(1,13,26,.6);backdrop-filter:blur(20px) saturate(1.4);-webkit-backdrop-filter:blur(20px) saturate(1.4);border-bottom:1px solid var(--glass-border);transition:background .3s,box-shadow .3s;}
.pk-hdr.scrolled{background:rgba(1,13,26,.88);box-shadow:0 8px 32px rgba(0,0,0,.4);}
.pk-hdr-inner{max-width:1340px;margin:0 auto;padding:0 24px;}
.pk-announce{padding:6px 0;border-bottom:1px solid rgba(0,229,255,.06);display:flex;justify-content:center;gap:24px;flex-wrap:wrap;}
.pk-ann{font-family:var(--ff);font-size:10px;font-weight:600;color:var(--frost);letter-spacing:.5px;display:flex;align-items:center;gap:5px;opacity:.7;}
.pk-ann i{font-size:9px;color:var(--ice);}
.pk-nav-row{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:10px 0;gap:16px;}
.pk-nav-left{display:flex;align-items:center;justify-content:flex-start;}
.pk-nav-center{display:flex;align-items:center;justify-content:center;}
.pk-nav-right{display:flex;align-items:center;justify-content:flex-end;gap:8px;}
.pk-logo{display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0;}
.pk-logo img{height:52px!important;width:auto!important;}
.pk-logo-mark{width:40px;height:40px;border-radius:10px;background:var(--g-aurora);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
@keyframes shimmer{0%,100%{transform:translateX(-100%)}50%{transform:translateX(100%)}}
.pk-logo-mark::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,transparent 40%,rgba(255,255,255,.2) 50%,transparent 60%);animation:shimmer 3s infinite;}
.pk-logo-mark i{font-size:18px;color:var(--abyss);position:relative;z-index:1;}
.pk-logo-text{font-family:var(--ff);font-size:18px;font-weight:800;color:#fff;letter-spacing:-.3px;}
.pk-logo-text span{color:var(--ice);}
.pk-links{display:flex;align-items:center;gap:2px;}
.pk-links a{font-family:var(--ff);font-size:13px;font-weight:500;color:var(--frost);padding:7px 14px;border-radius:8px;transition:.2s;position:relative;}
.pk-links a:hover,.pk-links a.active{color:#fff;background:rgba(0,229,255,.08);}
.pk-act-btn{width:44px;height:44px;border-radius:12px;background:rgba(0,229,255,.06);border:1px solid var(--glass-border);color:var(--frost);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;font-size:17px;text-decoration:none;position:relative;}
.pk-act-btn:hover{background:rgba(0,229,255,.12);color:#fff;border-color:rgba(0,229,255,.25);}
.pk-cart-btn{background:rgba(0,229,255,.1);border-color:rgba(0,229,255,.2);}
.pk-cart-btn:hover{background:rgba(0,229,255,.2);}
.pk-badge{position:absolute;top:-5px;right:-5px;width:18px;height:18px;border-radius:50%;background:var(--g-aurora);color:var(--abyss);font-size:9px;font-weight:800;display:flex;align-items:center;justify-content:center;font-family:var(--ff);}
.pk-mob{display:none;}.pk-desk{display:grid;}
@media(max-width:900px){
  .pk-desk{display:none!important;}
  .pk-mob{display:grid!important;grid-template-columns:auto 1fr auto;align-items:center;padding:10px 0;gap:8px;}
  .pk-mob-left{display:flex;align-items:center;}
  .pk-mob-center{display:flex;align-items:center;justify-content:center;}
  .pk-mob-center img{height:42px!important;width:auto!important;}
  .pk-mob-right{display:flex;align-items:center;justify-content:flex-end;gap:6px;}
  .pk-mob-btn{width:42px;height:42px;border-radius:12px;background:rgba(0,229,255,.06);border:1px solid var(--glass-border);color:var(--frost);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;font-size:17px;text-decoration:none;position:relative;flex-shrink:0;padding:0;}
  .pk-mob-btn:hover{background:rgba(0,229,255,.12);color:#fff;}
  .pk-mob-btn.cart-btn{background:rgba(0,229,255,.1);border-color:rgba(0,229,255,.2);}
  .pk-burger{width:42px;height:42px;border-radius:12px;background:rgba(0,229,255,.06);border:1px solid var(--glass-border);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;cursor:pointer;padding:0;}
  .pk-burger span{width:18px;height:2px;background:var(--frost);border-radius:2px;transition:.2s;}
  .pk-announce{display:none;}
}
.pk-oc{background:var(--abyss)!important;border-left:1px solid var(--glass-border)!important;max-width:300px!important;width:82%!important;}
.pk-oc .offcanvas-header{border-bottom:1px solid rgba(0,229,255,.06);padding:14px 16px;}
.pk-oc-hd{display:flex;align-items:center;justify-content:space-between;width:100%;}
.pk-oc-x{width:34px;height:34px;border-radius:10px;background:rgba(0,229,255,.06);border:1px solid var(--glass-border);color:var(--frost);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s;}
.pk-oc-age{display:flex;align-items:center;gap:8px;background:rgba(0,229,255,.04);border:1px solid rgba(0,229,255,.08);border-radius:10px;padding:10px 12px;margin:14px 16px;}
.pk-oc-age-b{font-family:var(--ff);font-size:14px;font-weight:800;color:var(--ice);background:rgba(0,229,255,.1);border-radius:6px;padding:2px 8px;}
.pk-oc-age-t{font-size:10px;color:var(--dim);line-height:1.4;}
.pk-oc-nav{padding:0 16px;}
.pk-oc-nav ul{list-style:none;padding:0;margin:0;}
.pk-oc-nav ul li{border-bottom:1px solid rgba(0,229,255,.05);}
.pk-oc-nav ul li a{display:block;padding:14px 4px;font-family:var(--ff);font-size:15px;font-weight:500;color:var(--frost);transition:.15s;}
.pk-oc-nav ul li a:hover{color:var(--ice);}
</style>

<div class="snow-wrap" id="pkSnow"></div>

<header class="pk-hdr" id="pkHdr">
  <div class="pk-hdr-inner">

    <div class="pk-announce">
      <span class="pk-ann"><i class="fas fa-snowflake"></i> Ilmainen toimitus yli 100€</span>
      <span class="pk-ann"><i class="fas fa-bolt"></i> 3–5 arkipäivän toimitus</span>
      <span class="pk-ann"><i class="fas fa-tags"></i> Tukkualennukset saatavilla</span>
    </div>

    <!-- ══ DESKTOP ══ -->
    <div class="pk-nav-row pk-desk">
      <div class="pk-nav-left">
        <nav class="pk-links">
          {%- if linklists[section.settings.menu].links.size > 0 -%}
            {%- for link in linklists[section.settings.menu].links -%}
              <a href="{{ link.url }}" {% if link.active %}class="active"{% endif %}>{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            <a href="{{ routes.all_products_collection_url }}">Kauppa</a>
            <a href="/pages/about-us">Tietoa meistä</a>
            <a href="/pages/faq">Yleiset kysymykset</a>
            <a href="/pages/contact-us">Ota yhteyttä</a>
          {%- endif -%}
        </nav>
      </div>

      <div class="pk-nav-center">
        <a href="{{ routes.root_url }}" class="pk-logo">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 240 }}" alt="{{ shop.name }}">
          {%- else -%}
            <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="height:52px;width:auto;">
          {%- endif -%}
        </a>
      </div>

      <div class="pk-nav-right">
        <a href="{{ routes.account_url }}" class="pk-act-btn" aria-label="Tili"><i class="fas fa-user"></i></a>
        <a href="#" data-emsc-open class="pk-act-btn pk-cart-btn" aria-label="Ostoskori">
          <i class="fas fa-shopping-bag"></i>
          <span class="pk-badge vs-cnt vs-cart-count">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>

    <!-- ══ MOBILE ══ -->
    <div class="pk-mob">
      <div class="pk-mob-left">
        <button class="pk-burger" data-bs-toggle="offcanvas" data-bs-target="#pkOC" aria-label="Valikko">
          <span></span><span></span><span></span>
        </button>
      </div>

      <div class="pk-mob-center">
        <a href="{{ routes.root_url }}" style="text-decoration:none;">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}">
          {%- else -%}
            <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="height:42px;width:auto;">
          {%- endif -%}
        </a>
      </div>

      <div class="pk-mob-right">
        <a href="{{ routes.account_url }}" class="pk-mob-btn" aria-label="Tili"><i class="fas fa-user"></i></a>
        <a href="#" data-emsc-open class="pk-mob-btn cart-btn" aria-label="Ostoskori">
          <i class="fas fa-shopping-bag"></i>
          <span class="pk-badge vs-mob-badge">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>

  </div>
</header>

<!-- ══ OFFCANVAS SIDEBAR ══ -->
<div class="offcanvas offcanvas-start pk-oc" tabindex="-1" id="pkOC">
  <div class="offcanvas-header">
    <div class="pk-oc-hd">
      <div>
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" style="height:40px;width:auto;">
        {%- else -%}
          <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="height:40px;width:auto;">
        {%- endif -%}
      </div>
      <button class="pk-oc-x" data-bs-dismiss="offcanvas" aria-label="Sulje"><i class="fas fa-times"></i></button>
    </div>
  </div>
  <div class="offcanvas-body" style="padding:0;">
    <div class="pk-oc-age">
      <div class="pk-oc-age-b">18+</div>
      <div class="pk-oc-age-t">Vain täysi-ikäisille. Sisältää nikotiinia.</div>
    </div>
    <nav class="pk-oc-nav">
      <ul>
        <li><a href="{{ routes.root_url }}">Etusivu</a></li>
        <li><a href="{{ routes.all_products_collection_url }}">Tuotteet</a></li>
        <li><a href="/pages/about-us">Tietoa meistä</a></li>
        <li><a href="/pages/faq">Yleiset kysymykset</a></li>
        <li><a href="/pages/contact-us">Ota yhteyttä</a></li>
      </ul>
    </nav>
  </div>
</div>

<script>
(function(){
  var hdr=document.getElementById('pkHdr');
  window.addEventListener('scroll',function(){hdr.classList.toggle('scrolled',window.scrollY>20);},{passive:true});
  var sw=document.getElementById('pkSnow');
  if(sw&&window.innerWidth>600){for(var s=0;s<25;s++){var p=document.createElement('i');var sz=Math.random()*3+1;p.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+Math.random()*100+'%;animation-duration:'+(Math.random()*8+6)+'s;animation-delay:'+(Math.random()*10)+'s;opacity:'+(Math.random()*.4+.1);sw.appendChild(p);}}
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "link_list",   "id": "menu", "label": "Main menu", "default": "main-menu" }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
