<div class="pk-cart">
  <h1 style="font-size:28px;font-weight:900;margin:0 0 18px;">{{ 'cart.title' | t | default: 'Ostoskori' }}</h1>

  {%- if cart.item_count == 0 -%}
    <p>Ostoskori on tyhjä. <a href="{{ routes.all_products_collection_url }}">Selaa tuotteita</a>.</p>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      {%- for item in cart.items -%}
        <div class="pk-cart-row">
          <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.product.title | escape }}">
          <div style="flex:1;">
            <a href="{{ item.url }}" style="color:var(--pk-text);font-weight:700;">{{ item.product.title }}</a>
            {%- if item.variant.title and item.variant.title != 'Default Title' -%}
              <div class="pk-text-muted" style="font-size:12px;">{{ item.variant.title }}</div>
            {%- endif -%}
            <div class="pk-text-accent" style="font-weight:800;margin-top:4px;">{{ item.final_line_price | money }}</div>
          </div>
          <div class="pk-qty">
            <button type="button" data-qty-dec>−</button>
            <input type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" inputmode="numeric">
            <button type="button" data-qty-inc>+</button>
          </div>
          <a href="{{ item.url_to_remove }}" aria-label="Remove" style="color:var(--pk-muted);font-size:20px;">&times;</a>
        </div>
      {%- endfor -%}

      <div class="pk-cart-totals">
        <div style="display:flex;justify-content:space-between;font-size:14px;color:var(--pk-muted);">
          <span>Välisumma</span><span style="color:var(--pk-text);font-weight:800;">{{ cart.total_price | money }}</span>
        </div>
        <div style="display:flex;gap:10px;margin-top:14px;">
          <button type="submit" name="update" class="pk-btn" style="background:#0b2545;color:var(--pk-text);">Päivitä</button>
          <button type="submit" name="checkout" class="pk-btn" style="flex:1;">Siirry kassalle</button>
        </div>
      </div>
    </form>
  {%- endif -%}
</div>

{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
