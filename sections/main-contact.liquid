<style>
.vcp{max-width:1100px;margin:0 auto;padding:0 20px 60px;}@media(max-width:768px){.vcp{padding:0 14px 50px;}}
.vcp-hero{background:var(--bg-deep);padding:52px 20px 44px;text-align:center;margin-bottom:36px;position:relative;overflow:hidden;}
.vcp-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(0,229,255,.1) 0%,transparent 60%);pointer-events:none;}
.vcp-hero h1{font-family:var(--ff);font-size:34px;font-weight:900;color:#fff;letter-spacing:-.6px;margin-bottom:10px;position:relative;z-index:1;}
.vcp-hero p{font-size:15px;color:rgba(202,240,248,.7);max-width:500px;margin:0 auto;line-height:1.6;position:relative;z-index:1;}
@media(max-width:768px){.vcp-hero{padding:36px 16px 30px;}.vcp-hero h1{font-size:26px;}.vcp-hero p{font-size:13.5px;}}
.vcp-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;}@media(max-width:768px){.vcp-grid{grid-template-columns:1fr;gap:16px;}}
.vcp-card{background:var(--w);border:1.5px solid var(--bdr);border-radius:14px;padding:28px;box-shadow:var(--sh);}@media(max-width:768px){.vcp-card{padding:20px 16px;}}
.vcp-card h2{font-family:var(--ff);font-size:20px;font-weight:800;color:var(--txt);margin-bottom:6px;letter-spacing:-.3px;}
.vcp-card .sub{font-size:13px;color:var(--mu);margin-bottom:22px;line-height:1.5;}
.vcp-frow{display:grid;grid-template-columns:1fr 1fr;gap:14px;}@media(max-width:480px){.vcp-frow{grid-template-columns:1fr;}}
.vcp-fg{margin-bottom:16px;}
.vcp-fg label{display:block;font-size:12px;font-weight:700;color:var(--mid);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px;}
.vcp-fg input,.vcp-fg textarea,.vcp-fg select{width:100%;padding:11px 14px;border:1.5px solid var(--bdr);border-radius:8px;font-size:13.5px;font-family:inherit;color:var(--txt);background:var(--bg2);outline:none;transition:.18s;}
.vcp-fg input:focus,.vcp-fg textarea:focus,.vcp-fg select:focus{border-color:var(--v);background:#0a1628;box-shadow:0 0 0 3px rgba(0,180,216,.1);}
.vcp-fg textarea{min-height:120px;resize:vertical;}
.vcp-fg select{-webkit-appearance:none;appearance:none;}
.vcp-submit{width:100%;padding:14px;margin-top:4px;background:var(--g);color:#0a1628;border:none;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 14px rgba(0,180,216,.25);transition:.18s;font-family:inherit;}
.vcp-submit:hover{opacity:.88;transform:translateY(-1px);}
.vcp-ok{display:none;margin-top:14px;padding:12px 16px;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:8px;color:#10b981;font-size:13.5px;font-weight:600;text-align:center;}
.vcp-info h3{font-family:var(--ff);font-size:18px;font-weight:800;color:var(--txt);margin-bottom:18px;letter-spacing:-.3px;}
.vcp-badge{background:rgba(0,180,216,.08);color:var(--f);border:1px solid var(--bdr);padding:12px 16px;border-radius:8px;font-size:13px;font-weight:700;text-align:center;margin-bottom:18px;display:flex;align-items:center;justify-content:center;gap:8px;}
.vcp-ii{display:flex;align-items:flex-start;gap:12px;padding:13px 14px;background:var(--bg2);border:1.5px solid var(--bdr);border-radius:8px;margin-bottom:10px;}
.vcp-ii-ico{width:36px;height:36px;border-radius:8px;background:var(--g);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.vcp-ii-ico i{font-size:15px;color:#0a1628;}
.vcp-ii-body h4{font-family:var(--ff);font-size:12px;font-weight:800;color:var(--mid);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px;}
.vcp-ii-body p,.vcp-ii-body a{font-size:13.5px;color:var(--txt);text-decoration:none;line-height:1.5;}
.vcp-ii-body a:hover{color:var(--f);}
</style>

<div class="vcp-hero">
  <h1><i class="fas fa-envelope" style="font-size:28px;display:block;margin-bottom:10px;"></i>Ota yhteyttä</h1>
  <p>Onko sinulla kysymyksiä tuotteista, tilauksesta tai toimituksesta? Olemme paikalla arkisin — lähetä meille viesti.</p>
</div>

<div class="vcp">
  <div class="vcp-grid">
    <div class="vcp-card">
      <h2>Lähetä meille viesti</h2>
      <p class="sub">Vastaamme yleensä 1 arkipäivän kuluessa.</p>
      {%- form 'contact', id: 'vcForm' -%}
        <div class="vcp-frow">
          <div class="vcp-fg"><label>Nimesi</label><input type="text" name="contact[name]" placeholder="Matti Meikäläinen" required></div>
          <div class="vcp-fg"><label>Sähköpostiosoite</label><input type="email" name="contact[email]" placeholder="matti@esimerkki.fi" required></div>
        </div>
        <div class="vcp-fg">
          <label>Aihe</label>
          <select name="contact[subject]">
            <option>Tilauksen kysymys</option>
            <option>Tuotteen kysymys</option>
            <option>Toimitusongelma</option>
            <option>Muu</option>
          </select>
        </div>
        <div class="vcp-fg"><label>Viesti</label><textarea name="contact[body]" placeholder="Kerro, miten voimme auttaa..." required></textarea></div>
        <button type="submit" class="vcp-submit"><i class="fas fa-paper-plane"></i> Lähetä viesti</button>
        {%- if form.posted_successfully? -%}
          <div class="vcp-ok" style="display:block;">✓ Viesti lähetetty! Palaamme asiaan pian.</div>
        {%- endif -%}
      {%- endform -%}
    </div>
    <div class="vcp-card vcp-info">
      <div class="vcp-badge"><i class="fas fa-headset"></i> Asiakaspalvelu ma–pe</div>
      <h3>Yhteystiedot</h3>
      <div class="vcp-ii"><div class="vcp-ii-ico"><i class="fas fa-envelope"></i></div><div class="vcp-ii-body"><h4>Sähköposti</h4><a href="mailto:info@pussikauppa.com">info@pussikauppa.com</a></div></div>
      <div class="vcp-ii"><div class="vcp-ii-ico"><i class="fas fa-clock"></i></div><div class="vcp-ii-body"><h4>Vastausaika</h4><p>Vastaamme yleensä 1 arkipäivän kuluessa.<br>Ma–Pe, asiakaspalvelu avoinna arkisin.</p></div></div>
      <div class="vcp-ii"><div class="vcp-ii-ico"><i class="fas fa-truck-fast"></i></div><div class="vcp-ii-body"><h4>Toimitus</h4><p>Toimitusaika 3–5 arkipäivää. Ilmainen yli 100€ tilauksiin.</p></div></div>
    </div>
  </div>
</div>

{% schema %}
{ "name": "Contact page", "settings": [] }
{% endschema %}
