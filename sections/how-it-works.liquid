<style>
.pk-how-section{position:relative;}
.pk-how-section::before{content:'';position:absolute;inset:0;background:rgba(1,13,26,.82);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);z-index:0;}
.pk-how-section .pk-wrap{position:relative;z-index:1;}
.pk-how{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
@media(max-width:768px){.pk-how{grid-template-columns:1fr;gap:24px;}}
.pk-how-visual{position:relative;aspect-ratio:3/4;border-radius:20px;overflow:hidden;background:var(--glass);border:1px solid var(--glass-border);}
.pk-how-visual img{width:100%;height:100%;object-fit:cover;}
.pk-how-visual::after{content:'';position:absolute;inset:0;background:linear-gradient(0deg,rgba(1,13,26,.6) 0%,transparent 50%);pointer-events:none;}
.pk-steps{display:flex;flex-direction:column;gap:24px;}
.pk-step{display:flex;gap:16px;align-items:flex-start;}
.pk-step-n{width:44px;height:44px;min-width:44px;border-radius:12px;background:var(--glass);border:1px solid var(--glass-border);display:flex;align-items:center;justify-content:center;font-family:var(--ff);font-size:16px;font-weight:800;color:var(--ice);position:relative;}
.pk-step-n::after{content:'';position:absolute;top:44px;left:50%;width:1px;height:calc(100% + 8px);background:rgba(0,229,255,.1);}
.pk-step:last-child .pk-step-n::after{display:none;}
.pk-step h4{font-family:var(--ff);font-size:16px;font-weight:700;color:#fff;margin-bottom:4px;}
.pk-step p{font-family:var(--fb);font-size:13px;color:var(--dim);line-height:1.6;}
</style>

{%- if section.settings.bg_image != blank -%}
  {%- assign how_bg = section.settings.bg_image | image_url: width: 1920 -%}
{%- else -%}
  {%- assign how_bg = 'ice.jpg' | asset_url -%}
{%- endif -%}
<section class="pk-sec pk-how-section" style="background:url('{{ how_bg }}') center/cover no-repeat fixed;">
  <div class="pk-wrap">
    <div class="pk-how pk-reveal">
      <div class="pk-how-visual">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
        {%- else -%}
          <img src="{{ 'pouche.jpeg' | asset_url }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
        {%- endif -%}
      </div>
      <div>
        <div class="pk-sec-hdr">
          <span class="pk-sec-eye">{{ section.settings.eyebrow | default: 'Näin helppoa se on' }}</span>
          <div class="pk-sec-title">{{ section.settings.heading | default: 'Kolme askelta nautintoon' }}</div>
          <p class="pk-sec-sub">{{ section.settings.subheading | default: 'Ei tupakkaa. Ei savua. Ei hajua. Vain puhdasta nikotiinia.' }}</p>
        </div>
        <div class="pk-steps">
          {%- for block in section.blocks -%}
            <div class="pk-step" {{ block.shopify_attributes }}>
              <div class="pk-step-n">{{ forloop.index }}</div>
              <div>
                <h4>{{ block.settings.title }}</h4>
                <p>{{ block.settings.text }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "max_blocks": 6,
  "settings": [
    { "type": "image_picker","id": "image",    "label": "Visual image" },
    { "type": "image_picker","id": "bg_image", "label": "Background image (optional)" },
    { "type": "text", "id": "eyebrow",    "label": "Eyebrow",    "default": "Näin helppoa se on" },
    { "type": "text", "id": "heading",    "label": "Heading",    "default": "Kolme askelta nautintoon" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Ei tupakkaa. Ei savua. Ei hajua. Vain puhdasta nikotiinia." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text",     "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text",  "label": "Text" }
      ]
    }
  ],
  "presets": [{
    "name": "How it works",
    "blocks": [
      { "type": "step", "settings": { "title": "Valitse brändisi",      "text": "Oden's, White Fox, VELO tai GREATEST. Seitsemän makua kaikilla vahvuuksilla." } },
      { "type": "step", "settings": { "title": "Aseta ylähuulen alle",  "text": "Nikotiini imeytyy limakalvon kautta. Vaikutus alkaa 1–2 minuutissa." } },
      { "type": "step", "settings": { "title": "Nauti 15–45 minuuttia", "text": "Pidä pussia paikallaan. Hävitä purkin kannen lokeroon tai roskikseen." } }
    ]
  }]
}
{% endschema %}
