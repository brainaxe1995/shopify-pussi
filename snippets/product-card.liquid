{%- comment -%} Port of WP content-product-tier.php — Pussikauppa Arctic Nordic product card with tier pricing.
                Currency forced to €-prefix Finnish format so server render matches JS update (no USD flash). {%- endcomment -%}
{%- assign p = product -%}
{%- assign sv = p.selected_or_first_available_variant -%}
{%- assign basePrice = sv.price | divided_by: 100.0 -%}
{%- assign regular = sv.compare_at_price | divided_by: 100.0 -%}
{%- assign on_sale = false -%}
{%- if regular > basePrice -%}{%- assign on_sale = true -%}{%- assign disc_pct = sv.compare_at_price | minus: sv.price | times: 100.0 | divided_by: sv.compare_at_price | round -%}{%- endif -%}
{%- assign nic = p.metafields.custom.nicotine_strength -%}
{%- assign koko = p.metafields.custom.pouch_size -%}
{%- assign maara = p.metafields.custom.pouches_per_can | default: 20 -%}

{%- comment -%} Tier table — same as WP pk_get_qty_tiers(): 1=>0, 5=>3, 10=>5, 50=>7, 100=>10. {%- endcomment -%}
{%- assign tier_default_qty = 10 -%}
{%- assign tier_default_disc = 5 -%}
{%- assign alk_unit = basePrice | times: 90.0 | divided_by: 100.0 -%}
{%- assign def_unit = basePrice | times: 95.0 | divided_by: 100.0 -%}
{%- assign def_total = def_unit | times: tier_default_qty -%}

{%- comment -%} Euro formatter helper — split into int + 2-decimal comma. {%- endcomment -%}
{%- capture eur_alk -%}{%- assign a = alk_unit -%}{%- assign ai = a | floor -%}{%- assign ad = a | minus: ai | times: 100 | round -%}€ {{ ai }},{% if ad < 10 %}0{% endif %}{{ ad }}{%- endcapture -%}
{%- capture eur_unit -%}{%- assign u = def_unit -%}{%- assign ui = u | floor -%}{%- assign ud = u | minus: ui | times: 100 | round -%}€ {{ ui }},{% if ud < 10 %}0{% endif %}{{ ud }}{%- endcapture -%}
{%- capture eur_total -%}{%- assign t = def_total -%}{%- assign ti = t | floor -%}{%- assign td = t | minus: ti | times: 100 | round -%}€ {{ ti }},{% if td < 10 %}0{% endif %}{{ td }}{%- endcapture -%}

<div class="pk-card" data-card-base="{{ basePrice }}">
  <a class="pk-img" href="{{ p.url }}?tier={{ tier_default_qty }}">
    {%- if on_sale -%}
      <span class="pk-sale">-{{ disc_pct }}%</span>
    {%- endif -%}
    {%- if p.featured_image -%}
      <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy">
    {%- else -%}
      <img src="{{ 'pouche.jpeg' | asset_url }}" alt="{{ p.title | escape }}" loading="lazy">
    {%- endif -%}
  </a>
  <div class="pk-body">
    <a href="{{ p.url }}" class="pk-name">{{ p.title }}</a>
    <div class="pk-alk">Alk. <span>{{ eur_alk }}</span></div>
    <div class="pk-specs">
      {%- if nic != blank -%}<span class="pk-sp">{{ nic }}</span>{%- endif -%}
      {%- if koko != blank -%}<span class="pk-sp">{{ koko }}</span>{%- endif -%}
      <span class="pk-sp">{{ maara }} pussia</span>
    </div>

    <div class="pk-tiers" data-base="{{ basePrice }}">
      <div class="pk-tpills">
        <a href="{{ p.url }}?tier=1"   class="pk-tp" data-qty="1"   data-disc="0"  onclick="pkTier(this,event)">1 kpl</a>
        <a href="{{ p.url }}?tier=5"   class="pk-tp" data-qty="5"   data-disc="3"  onclick="pkTier(this,event)">5 kpl</a>
        <a href="{{ p.url }}?tier=10"  class="pk-tp pk-tp-active" data-qty="10" data-disc="5" onclick="pkTier(this,event)">10 kpl</a>
        <a href="{{ p.url }}?tier=50"  class="pk-tp" data-qty="50"  data-disc="7"  onclick="pkTier(this,event)">50 kpl</a>
        <a href="{{ p.url }}?tier=100" class="pk-tp" data-qty="100" data-disc="10" onclick="pkTier(this,event)">100 kpl</a>
      </div>
      <div class="pk-tinfo">
        <span class="tiq">{{ tier_default_qty }}x</span>
        <span class="tip">{{ eur_unit }}</span>
        <span class="tid">-{{ tier_default_disc }}%</span>
      </div>
      <div class="pk-ttot">
        <span class="ttl">Yhteensä</span>
        <span class="ttp">{{ eur_total }}</span>
      </div>
    </div>

    <a href="{{ p.url }}?tier={{ tier_default_qty }}" class="pk-btn" data-link="{{ p.url }}">
      <i class="fas fa-shopping-bag"></i> Osta nyt
    </a>
  </div>
</div>
